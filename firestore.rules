rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /triage_records/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (getUserData().role in ['Admin', 'Doctor']);
    }

    match /broadcasts/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (getUserData().role in ['Admin', 'NGO']);
    }
    
    match /resources/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (getUserData().role in ['Admin', 'NGO']);
    }

    match /responder_locations/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
  }
}
